{
    # Global options
    # email your-email@example.com
    admin off
}

(security) {
    header {
        # Enable HSTS
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # Disable content type sniffing
        X-Content-Type-Options "nosniff"
        # XSS protection & Frame options
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
        # Remove server header
        -Server
    }
}

# 1. THE ARCHITECT (High-Fidelity Web UI)
chat.save-aichats.com {
    import security
    encode gzip zstd
    reverse_proxy localhost:3099
    
    log {
        output file /var/log/caddy/chat-access.log {
            roll_size 10MB
            roll_keep 5
        }
    }
}

# 2. THE ENGINE (Raw API Layer)
engine.save-aichats.com {
    import security
    encode gzip
    reverse_proxy localhost:3099
    
    log {
        output file /var/log/caddy/engine-access.log {
            roll_size 10MB
            roll_keep 5
        }
    }
}

